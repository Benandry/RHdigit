{% extends 'base.html.twig' %}

{% block title %}
	{{ parent() }}
	- Gestion des utilisateurs
{% endblock %}


{% block body %}
	<div class="p-8">
		<div class="flex justify-between items-center mb-6">
			<h1 class="text-2xl font-bold text-gray-800">Listes des utilisateur</h1>
		</div>

		<div class="bg-white rounded-xl shadow-sm overflow-hidden">
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-gray-200">
					<thead class="bg-gray-50">
						<tr>
							<th class="px-6 py-3 text-left  font-medium text-gray-500 uppercase tracking-wider">Nom d'utilisateur</th>
							<th class="px-6 py-3 text-left  font-medium text-gray-500 uppercase tracking-wider">Nom  </th>
							<th class="px-6 py-3 text-left  font-medium text-gray-500 uppercase tracking-wider">Prénom</th>
							<th class="px-6 py-3 text-left  font-medium text-gray-500 uppercase tracking-wider">Email</th>
							<th class="px-6 py-3 text-left  font-medium text-gray-500 uppercase tracking-wider">Status</th>
							<th class="px-6 py-3 text-left  font-medium text-gray-500 uppercase tracking-wider">Actions</th>
						</tr>
					</thead>
					<tbody class="bg-white divide-y divide-gray-200">
						{% for user in users %}
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 whitespace-nowrap  text-gray-900">{{ user.username }} </td>
								<td class="px-6 py-4 whitespace-nowrap  text-gray-900">{{ user.firtName }}</td>
								<td class="px-6 py-4 whitespace-nowrap  text-gray-900">{{ user.lastName }}</td>
								<td class="px-6 py-4 whitespace-nowrap  text-gray-900">{{ user.email }}</td>
								<td class="px-6 py-4 whitespace-nowrap  text-gray-900">{{ user.status }}</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="4" class="px-6 py-4 text-center text-gray-500">
									Aucun enregistrement trouvé
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
