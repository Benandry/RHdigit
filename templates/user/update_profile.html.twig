{% extends 'base.html.twig' %}

{% block title %}Update Profile{% endblock %}

{% block body %}
<div class="bg-gray-100 flex justify-center py-10 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-3xl bg-white rounded-2xl shadow-lg overflow-hidden transition-all">
        {{ form_start(form_profile, {'attr': {'class': 'w-full flex flex-col md:flex-row', 'enctype': 'multipart/form-data'}}) }}

        <!-- Sidebar Avatar -->
        <div class="w-full md:w-1/3 bg-gradient-to-b from-blue-50 to-white p-6 sm:p-8 border-b md:border-b-0 md:border-r border-gray-200 flex flex-col items-center justify-center">
            <div class="relative mb-5 group">
                <img id="avatar-preview"
                     src="{{ user_profile.avatarUrl | default('https://ui-avatars.com/api/?name=' ~ user_profile.firstName ~ '+' ~ user_profile.lastName ~ '&background=EBF4FF&color=1E3A8A&size=256') }}"
                     alt="{{ user_profile.firstName }}'s Avatar"
                     class="w-32 h-32 rounded-full object-cover border-4 border-white shadow-md transition-all duration-300 transform hover:scale-105">

                <label for="avatar-upload"
                       class="absolute bottom-1 right-1 bg-blue-600 text-white p-2 rounded-full cursor-pointer shadow-md hover:bg-blue-700 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500 transition duration-150 ease-in-out"
                       title="Change Profile Picture">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <input type="file" id="avatar-upload" name="avatar_upload" class="sr-only" accept="image/*" onchange="previewImage(event)">
                </label>
            </div>

            <h2 class="text-xl font-bold text-gray-900 text-center">{{ user_profile.firstName }} {{ user_profile.lastName }}</h2>
            <p class="text-sm text-gray-500 text-center mt-1">{{ user_profile.email }}</p>
        </div>

        <!-- Form Content -->
        <div class="w-full md:w-2/3 p-6 sm:p-8">
            <h3 class="text-lg font-semibold text-gray-900 mb-6 border-b border-gray-100 pb-3">Profile Information</h3>

            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
                {% for field in ['firstName', 'lastName', 'email', 'username'] %}
                    <div class="sm:col-span-1">
                        {{ form_label(attribute(form_profile, field), null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(attribute(form_profile, field), {'attr': {
                            'class': 'w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none transition duration-150 sm:text-sm',
                            'placeholder': field == 'plainPassword' ? 'Leave blank to keep current' : ''
                        }}) }}
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(attribute(form_profile, field)) }}</div>
                    </div>
                {% endfor %}
            </div>

            <!-- Buttons -->
            <div class="mt-8 flex flex-col-reverse sm:flex-row justify-end gap-3 pt-5 border-t border-gray-100">
                <button type="button" onclick="history.back()" class="w-full sm:w-auto px-5 py-2.5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200">
                    Cancel
                </button>
                <button type="submit" class="w-full sm:w-auto px-5 py-2.5 border border-transparent shadow-lg text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-200 transform hover:scale-105 flex justify-center items-center">
                    Update Profile
                </button>
            </div>
        </div>

        {{ form_end(form_profile) }}
    </div>
</div>

<script>
function previewImage(event) {
    const input = event.target;
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('avatar-preview').src = e.target.result;
        }
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
{% endblock %}