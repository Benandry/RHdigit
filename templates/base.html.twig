<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Admin RD
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
			{# Tailwind should be compiled via app.js with PostCSS/Tailwind plugin, not included via CDN #}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}
	</head>
	<body class="bg-gray-200 text-gray-800 font-sans antialiased text-lg">
		<div
			class="flex min-h-screen">
			<!-- Sidebar -->
			{{ include('layout/_sidebar.html.twig') }}

			<!-- Main Content -->
			<div
				class="ml-xl flex-1">
				<!-- Navbar -->
				{{ include('layout/_navbar.html.twig') }}
				<!-- Content -->
				<main class="w-full p-4"> {% block body %}{% endblock %} </main>

				</div>
			</div>
		</body>
	</html>
