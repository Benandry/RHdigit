<aside class="w-sm bg-gradient-to-br from-gray-800 to-blue-900 shadow-xl left-0 min-h-screen border-r border-gray-700 z-50">
    <div class="p-6">
        <h2 class="text-white text-xl font-bold truncate">
            RH<span class="text-blue-400">digit</span>
        </h2>
    </div>

    {% set current_path = app.request.get('_route') %}

    {# Définition des menus principaux avec sous-menus #}
    {% set menus = {
        'Ressources humaines': {
            'icon': 'fas fa-layer-group',
            'items': {
                'app_employee.index': ['Employés', 'fas fa-user'],
                'app_departement.index': ['Département', 'fas fa-building'],
                'app_contrat.index': ['Contrat', 'fas fa-file-contract'],
                'app_poste.index': ['Poste', 'fas fa-briefcase']
            }
        },
        'Achats': {
            'icon': 'fas fa-shopping-cart',
            'items': {
                'inactive_orders': ['Commandes', 'fas fa-receipt'],
                'inactive_suppliers': ['Fournisseurs', 'fas fa-truck']
            }
        },
        'Finance et Comptabilité': {
            'icon': 'fas fa-chart-line',
            'items': {
                'inactive_compta': ['Comptabilité', 'fas fa-receipt'],
                'inactive_tresorerie': ['Trésorerie', 'fas fa-wallet'],
                'inactive_budget': ['Budget', 'fas fa-piggy-bank']
            }
        },
        'CRM': {
            'icon': 'fas fa-handshake',
            'items': {
                'inactive_clients': ['Clients', 'fas fa-user-friends'],
                'inactive_deals': ['Affaires', 'fas fa-briefcase']
            }
        },
        'Projet et BI': {
            'icon': 'fas fa-project-diagram',
            'items': {
                'inactive_projects': ['Gestion de projets', 'fas fa-tasks'],
                'inactive_bi': ['Business Intelligence', 'fas fa-chart-bar'],
                'inactive_reporting': ['Rapports et Exports', 'fas fa-file-alt']
            }
        },
        'Production et Logistique': {
            'icon': 'fas fa-industry',
            'items': {
                'inactive_production': ['Production', 'fas fa-cogs'],
                'inactive_logistics': ['Stock et Entrepôt', 'fas fa-warehouse'],
                'inactive_transport': ['Transports et Livraisons', 'fas fa-truck']
            }
        },
        'Administration': {
            'icon': 'fas fa-cogs',
            'items': {
                'app_user.list': ['Utilisateurs & Rôles', 'fas fa-user-shield'],
                'inactive_settings': ['Paramètres système', 'fas fa-cogs'],
                'inactive_audit': ['Journal d\'audit', 'fas fa-file-alt'],
                'inactive_api': ['Intégrations & API', 'fas fa-plug']
            }
        }
    } %}

    <nav class="mt-6 px-4" x-data="{ openMenu: '{{ menus|keys|first }}' }">
        <div class="space-y-2">
            
            <!-- Dashboard -->
            <a href="{{ path('app_home') }}"
               class="flex items-center gap-3 px-4 py-3 {{ current_path == 'app_home' ? 'bg-blue-900/30 text-blue-300' : 'text-gray-300'}} rounded-lg hover:bg-gray-800/30 hover:text-white transition">
                <i class="fas fa-home h-5 w-5"></i>
                <span class="font-medium truncate">Tableau de bord</span>
            </a>

             <!-- Notifications -->
            <a href="{{ path('app_home') }}"
               class="flex items-center gap-3 px-4 py-3 {{ current_path == 'app_home' ? 'bg-blue-900/30 text-blue-300' : 'text-gray-300'}} rounded-lg hover:bg-gray-800/30 hover:text-white transition">
                <i class="fas fa-bell h-5 w-5"></i>
                <span class="font-medium truncate">Notifications</span>
            </a>

            {# Boucle sur les menus principaux #}
            {% for menu_name, menu_data in menus %}
                <div>
                    <button 
                        @click="openMenu = (openMenu === '{{ menu_name }}' ? '' : '{{ menu_name }}')"
                        class="w-full flex items-center justify-between px-4 py-3 text-gray-300 hover:bg-gray-800/30 hover:text-white rounded-lg transition">
                        
                        <div class="flex items-center gap-3">
                            <i class="{{ menu_data.icon }} h-5 w-5"></i>
                            <span class="font-medium truncate" title="{{ menu_name }}">{{ menu_name }}</span>
                        </div>

                        <i class="fas fa-chevron-down inline-block"
                           :style="openMenu === '{{ menu_name }}' ? 'transform: rotate(0deg); transition: transform 0.3s ease-in-out;' : 'transform: rotate(-90deg); transition: transform 0.3s ease-in-out;'"></i>
                    </button>

                    <!-- Dropdown -->
                    <div x-show="openMenu === '{{ menu_name }}'"
                         x-transition:enter="transition ease-out duration-300"
                         x-transition:enter-start="opacity-0 scale-y-90 max-h-0"
                         x-transition:enter-end="opacity-100 scale-y-100 max-h-96"
                         x-transition:leave="transition ease-in duration-200"
                         x-transition:leave-start="opacity-100 scale-y-100 max-h-96"
                         x-transition:leave-end="opacity-0 scale-y-90 max-h-0"
                         class="overflow-hidden pl-10 mt-2 space-y-1">
                        
                        {% for route, data in menu_data.items %}
                            <a href="{{ route starts with 'inactive_' ? '#' : path(route) }}"
                               class="flex items-center gap-2 px-4 py-2 rounded-lg text-lg
                                      {{ route starts with 'inactive_' ? 'text-gray-500 cursor-not-allowed' : (current_path starts with route|split('.')|first ~ '.' ? 'bg-blue-900/30 text-blue-300' : 'text-gray-400 hover:text-white') }}
                                      hover:bg-gray-800/30 transition truncate"
                               title="{{ data[0] }}">
                                <i class="{{ data[1] }} w-4 h-4"></i>
                                <span>{{ data[0] }}</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}

        </div>

        <!-- User -->
        <div class="absolute bottom-0 w-full left-0 p-4">
            <div class="flex items-center gap-3">
                <div class="rounded-full w-10 h-10 ring-2 ring-blue-400 flex items-center justify-center">
                    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                </div>
                <div class="truncate">
                    <p class="text-white font-medium truncate">{{ app.user.username }}</p>
                    <p class="text-gray-400 truncate">{{ app.user.email }}</p>
                </div>
            </div>
        </div>
    </nav>
</aside>